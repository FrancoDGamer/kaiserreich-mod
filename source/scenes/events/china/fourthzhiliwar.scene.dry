title: Border clashes around Yan
subtitle: Is war on the horizon?!
on-arrival: {!
!}
tags: event
view-if: year = 1928 and month = 3
priority: 2
max-visits: 1

The newspapers in Germany are aripe with news. A series of communiques have came out via telegraph from the Yunnan and Shanxi provinces declaring the Qing government illegitimate. At the same time, the Chinese Warlord Zhang Zuolin has began 

Just barely one year ago, the German Empire had intervened in China in favour of the Zhili clique. Though it avoided further encroachement of Japanese influence, the gains from  are yet to be seen 



The Reichskanzler, Ulrich von Brockdorff-Rantzau, has currently . 

- @wait: Wait for further developments on the situation 
- @preempt: Pre-empt the chancellor's move and call an emergency party congress to determine our next steps.

@wait 

Nothing happens

@preempt 
subtitle: Seen as a nuclear answer to the news at this stage in time, this will enable us to choose a stance on the war, from opposing it to supporting it.
on-arrival: {!
Q.total_influence = Math.round(Q.spd_r * 5);

for (var faction of Q.factions) {
    Q[faction + '_influence'] = (Q.total_influence * (Q[faction + '_strength']/100));  
    Q[faction + '_influence' + '_display'] = Math.round(Q[faction + '_influence']);
    Q[faction + '_percentage'] = Q[faction + '_influence']/Q.total_influence;
}

Q.left_influence = ((Q.pseudo_syndicalist_influence + Q.classical_marxist_influence + Q.spartacist_influence)/Q.total_influence)*100;

Q.right_influence = ((Q.staatspolitiker_influence + Q.social_liberal_influence + Q.national_socialist_influence)/Q.total_influence)*100;

Q.center_influence = ((Q.centrist_influence + Q.austromarxist_influence + Q.pragmatist_influence)/Q.total_influence)*100;

Q.labor_influence = ((Q.populist_influence + Q.trade_union_influence + Q.codeterminist_influence)/Q.total_influence)*100;

Q.young_turk_influence = ((Q.hanover_influence + Q.neorevisionist_influence)/Q.total_influence)*100;


Q.left_influence_percentage = (((Q.pseudo_syndicalist_influence + Q.classical_marxist_influence + Q.spartacist_influence)/Q.total_influence)*100).toFixed(1);

Q.right_influence_percentage = (((Q.staatspolitiker_influence + Q.social_liberal_influence + Q.national_socialist_influence)/Q.total_influence)*100).toFixed(1);

Q.center_influence_percentage = (((Q.centrist_influence + Q.austromarxist_influence + Q.pragmatist_influence)/Q.total_influence)*100).toFixed(1);

Q.labor_influence_percentage = (((Q.populist_influence + Q.trade_union_influence + Q.codeterminist_influence)/Q.total_influence)*100).toFixed(1);

Q.young_turk_influence_percentage = (((Q.hanover_influence + Q.neorevisionist_influence)/Q.total_influence)*100).toFixed(1);


Q.left_delegates = Math.round(Q.pseudo_syndicalist_influence + Q.classical_marxist_influence + Q.spartacist_influence);

Q.right_delegates = Math.round(Q.staatspolitiker_influence + Q.social_liberal_influence + Q.national_socialist_influence);

Q.center_delegates = Math.round(Q.centrist_influence + Q.austromarxist_influence + Q.pragmatist_influence);

Q.labor_delegates = Math.round(Q.populist_influence + Q.trade_union_influence + Q.codeterminist_influence);

Q.young_turk_delegates = Math.round(Q.hanover_influence + Q.neorevisionist_influence);


Q.zhili_antiwar = 0;

Q.zhili_prowar = 0;

Q.zhili_neutral = 0;

Q.zhili_principled = 0;

Q.zhili_free = 0;

Q.zhili_china = 0;

Q.zhili_ignore = 0;

Q.zhili_opposition = 0;

!}
