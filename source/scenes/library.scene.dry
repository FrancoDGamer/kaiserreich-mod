title: Library
new-page: true
is-special: true
on-arrival: {!
const toolsWrapper = document.getElementById('tools_wrapper');

if (toolsWrapper) {
  toolsWrapper.style.display = 'none';
}
!}
on-departure: {!
    if (toolsWrapper) {
  toolsWrapper.style.display = 'block';
}
!}

